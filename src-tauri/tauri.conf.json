{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuotaDock",
  "version": "0.2.9",
  "identifier": "com.rupingliu.quotadock",
  "mainBinaryName": "quotadock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "beforeBundleCommand": "node scripts/sync-webview2-loader.mjs",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "QuotaDock",
        "width": 306,
        "height": 92,
        "visible": false,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": {
      "resources/windows/WebView2Loader.dll": "WebView2Loader.dll"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

